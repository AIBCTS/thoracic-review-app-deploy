	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	file = {PDF:/Users/johan/Zotero/storage/PN44WCAI/Woodruff et al. - 2026 - Accelerating Scientific Research with Gemini Case Studies and Common Techniques.pdf:application/pdf},
