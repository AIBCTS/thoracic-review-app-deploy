	keywords = {Adolescent, Adult, Female, Humans, Male, Middle Aged, Retrospective Studies, *Heart Transplantation, Time Factors, Young Adult, *Registries, Age Distribution, Follow-Up Studies, Heart transplantation, Heart failure, Mechanical circulatory support, Continuous flow left ventricular assist device, Heart Failure/*surgery, Heart-Assist Devices/statistics \& numerical data/*trends},
