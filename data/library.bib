@article{nozohoor_postoperative_2011,
	title = {Postoperative increase in {B}-type natriuretic peptide levels predicts adverse outcome after cardiac surgery},
	volume = {25},
	issn = {1532-8422 (Electronic) 1053-0770 (Linking)},
	doi = {10.1053/j.jvca.2010.07.002},
	abstract = {OBJECTIVE: To evaluate the prognostic implication of changes in postoperative B-type natriuretic peptide (BNP) concentrations in patients undergoing cardiopulmonary bypass for cardiac surgery. DESIGN: A retrospective analysis of prospectively collected clinical data. SETTING: Cardiothoracic surgery and an intensive care unit (ICU) in a university hospital. PARTICIPANTS: The present study included a total of 407 consecutive patients undergoing cardiac surgery. INTERVENTIONS: None. MEASUREMENTS AND MAIN RESULTS: BNP concentrations were measured on admittance to the ICU (D0) and at day 1 after surgery. Patients were divided into quintiles according to their BNP level on admittance to the ICU. The predictive value of absolute changes in BNP levels during the first 24 hours postoperatively was analyzed with Kaplan-Meier estimates of survival and Cox multivariate proportional analysis. Prognostic factors for impaired midterm survival included elevation of the BNP level (HR, 7.3/ log10(x); 95\% confidence interval, 1.8-29, p = 0.005). The BNP levels of patients undergoing isolated valve surgery or valve and concomitant CABG surgery were significantly higher (p = 0.012 and p = 0.032, respectively) than those undergoing isolated coronary artery bypass graft surgery. Patients in higher quintiles required ventilation for a longer time (p {\textless} 0.001), and prolonged inotropic support (p {\textless} 0.001). The mean plasma BNP concentration of 172 pg/mL (median, 64; interquartile range, 172) on arrival at the ICU had a sensitivity of 75\% and a specificity of 74\% for predicting 1-year mortality. CONCLUSIONS: Elevated BNP levels on admittance to the ICU and postoperatively increasing BNP levels are associated with adverse postoperative outcome and are predictive of impaired late survival. Sequential postoperative BNP monitoring facilitates the early identification of patients at an increased risk of heart failure and may be used as an adjunct for clinical decision making and optimized patient management.},
	language = {eng},
	number = {3},
	journal = {Journal of Cardiothoracic and Vascular Anesthesia},
	author = {Nozohoor, S. and Nilsson, J. and Algotsson, L. and Sjogren, J.},
	month = jun,
	year = {2011},
	keywords = {Aged, Female, Humans, Male, Middle Aged, Predictive Value of Tests, Retrospective Studies, Follow-Up Studies, Prospective Studies, Aged, 80 and over, Treatment Outcome, Biomarkers/blood, Cardiac Surgical Procedures/*adverse effects, Natriuretic Peptide, Brain/biosynthesis/*blood, Postoperative Complications/*blood/*diagnosis/etiology},
	pages = {469--75},
	file = {Nozohoor-2011-Postoperative increa:/Users/johan/Zotero/storage/C8CJGYCT/Nozohoor-2011-Postoperative increa.pdf:application/pdf},
}

@article{nozohoor_case-controlled_2012,
	title = {A case-controlled evaluation of the {Medtronic} {Resting} {Heart} {System} compared with conventional cardiopulmonary bypass in patients undergoing isolated coronary artery bypass surgery},
	volume = {14},
	issn = {1569-9285 (Electronic) 1569-9293 (Print) 1569-9285 (Linking)},
	doi = {10.1093/icvts/ivr158},
	abstract = {The Medtronic Resting Heart System (RHS) is a heparin-coated, closed perfusion circuit. Clinical results indicate less haemodilution and reduced complement activation, when compared with a traditional circuit leading to fewer postoperative blood transfusions. We evaluated the potential clinical benefits, including reduced transfusion requirements, when using the RHS compared with conventional cardiopulmonary bypass (cCPB). The study group (n = 330) consisted of patients undergoing isolated coronary artery bypass grafting (CABG) using the RHS system during 2005-2009, matched with a control group (n = 609) including patients operated for isolated CABG during 2002-2009, utilizing cCPB. Significantly fewer patients received peri- and postoperative blood transfusions in the RHS group (25 vs. 37\%, P {\textless} 0.001; mean 1.0 +/- 2.6 vs. mean 1.6 +/- 2.9 units of packed red blood cells). The incidence of reoperations due to bleeding was low, RHS 2\% (n = 8) vs. cCPB 5\% (n = 29), with a trend towards no significant difference between groups (P = 0.079). The duration of mechanical ventilation was shorter (mean 7 +/- 16 vs. 9 +/- 12 h, P {\textless} 0.001) for patients in the RHS group. This study demonstrates that CABG performed with the RHS reduces the incidence and magnitude of allogenic blood transfusion and results in a satisfactory clinical outcome.},
	language = {eng},
	number = {5},
	journal = {Interactive cardiovascular and thoracic surgery},
	author = {Nozohoor, S. and Johnsson, P. and Scicluna, S. and Wallentin, P. and Andell, E. and Nilsson, J.},
	month = may,
