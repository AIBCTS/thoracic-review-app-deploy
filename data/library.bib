	keywords = {Adolescent, Adult, Female, Humans, Male, Risk Factors, Retrospective Studies, *Heart Transplantation, Young Adult, Follow-Up Studies, Child, Child, Preschool, Infant, heart transplantation, Absorptiometry, Photon, Age Factors, Bone Density/*physiology, bone mineral density, immunosuppression, Osteoporosis/diagnosis/*etiology/physiopathology, pediatric, Postoperative Complications/diagnosis/*etiology/physiopathology},
