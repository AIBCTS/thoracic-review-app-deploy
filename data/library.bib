@article{jernryd_donor_2025,
	title = {Donor age and ischemic time in heart transplantation - implications for organ preservation},
	volume = {44},
	issn = {1557-3117 (Electronic) 1053-2498 (Linking)},
	doi = {10.1016/j.healun.2024.10.030},
	abstract = {BACKGROUND: The Organ Care System and Non-ischemic Heart Preservation methods have emerged as significant advancements in heart transplantation, designed to mitigate ischemic injury and extend preservation times. However, their high costs and logistical complexities necessitate strategic utilization. METHODS: We evaluated data from 83,761 heart transplants registered in the International Society for Heart and Lung Transplantation registry from 1988 to 2018. Utilizing a Cox proportional hazards model, we explored the influence of donor age and ischemic time on transplant survival. A key innovation of our study is the development of a nomogram to predict post-transplant survival, incorporating both traditional and advanced statistical methods. RESULTS: The median age of recipients was 52 years (22\% female) and 33 years (31\% female) for donors. Analysis revealed a median ischemic time of 3 hours and median survival of 11.5 years across the cohort. The nomogram showed a decline in survival probabilities with increasing donor age, notably from age 40 and more significantly with ischemic times {\textgreater}4 hours. Ischemic times {\textgreater}/=4 hours versus {\textless}2 hours were associated with hazard ratio (HR) of 1.2 (95\% CI, 1.1-1.3) for donors aged 40-59, a disparity that escalated for donors aged {\textgreater}/=60 (HR: 2.0; 95\% CI, 1.5-2.7). CONCLUSIONS: This study highlights the importance of careful donor selection and indicates that certain groups, particularly older donors with prolonged ischemic times, might benefit from ex-vivo preservation techniques. The developed nomogram offers a practical tool for clinicians, enhancing decision-making by providing detailed insights into the relationship between donor age, ischemic time, and post-transplant mortality.},
	number = {3},
	journal = {J Heart Lung Transplant},
	author = {Jernryd, V. and Stehlik, J. and Metzsch, C. and Lund, L. H. and Gustav Smith, J. and Andersson, B. and Perez, R. and Nilsson, J.},
	month = mar,
	year = {2025},
	keywords = {Adult, Female, Humans, Male, Middle Aged, Retrospective Studies, Time Factors, *Registries, Survival Rate/trends, survival, *Organ Preservation/methods, heart transplantation, *Heart Transplantation/methods, Age Factors, *Tissue Donors, Cold Ischemia, donor age, ex-vivo preservation, ischemic time},
	pages = {364--375},
	file = {Jernryd-2024-Donor age and ischemic time in he:/Users/johan/Zotero/storage/GU6A48XG/Jernryd-2024-Donor age and ischemic time in he.pdf:application/pdf},
}

@article{jernryd_myocardial_2022,
	title = {Myocardial injury biomarkers at point of care for early identification of primary graft dysfunction after heart transplantation},
	volume = {36},
	issn = {1399-0012 (Electronic) 0902-0063 (Linking)},
	doi = {10.1111/ctr.14526},
	abstract = {INTRODUCTION: Primary graft dysfunction (PGD) is a leading cause of 30-day mortality following heart transplantation, and early intervention in PGD may correlate to improved survival. Our analysis aimed to determine the feasibility of measuring cardiac biomarkers from the donor heart in the early phase for use as a predictor of PGD. METHODS: Blood samples from the coronary sinus were obtained at the time of transplantation in hearts preserved by cold static storage. The samples were analyzed for CK-MB and cTnI with a point-of-care method. The primary outcome was severe PGD or the need for veno-arterial extracorporeal membrane oxygenation within 7 days, referred to as severe graft dysfunction. RESULTS: Of the total cohort (n = 63), eight patients (13\%) were diagnosed with severe graft dysfunction within 7 days. Patients with high CK-MB had an increased risk for severe graft dysfunction with unadjusted Odds Ratio (OR) of 4.5 (95\%CI .96-21.11 P = .057) and adjusted OR of 7.4 (95\%CI 1.13-48.46, P = .037. Similar but non significant trends were observed for cTnI. CONCLUSION: By measuring CK-MB from the coronary effluent in the donor heart, it may be possible to identify patients at increased risk for severe PGD after heart transplantation.},
	number = {2},
	journal = {Clin Transplant},
	author = {Jernryd, V. and Metzsch, C. and Andersson, B. and Smith, J. G. and Nilsson, J.},
	month = feb,
	year = {2022},
	keywords = {Humans, Retrospective Studies, *Heart Transplantation, biomarker, heart transplantation, Tissue Donors, Biomarkers, *Lung Transplantation/adverse effects, *Primary Graft Dysfunction/diagnosis/etiology, Point-of-Care Systems, primary graft dysfunction},
	pages = {e14526},
	file = {Jernryd-2022-Myocardial injury biomarkers at p:/Users/johan/Zotero/storage/PDBL7TUE/Jernryd-2022-Myocardial injury biomarkers at p.pdf:application/pdf},
}

@article{jernryd_influence_2020,
	title = {The influence of ischemia and reperfusion time on outcome in heart transplantation},
	volume = {34},
	issn = {1399-0012 (Electronic) 0902-0063 (Linking)},
	doi = {10.1111/ctr.13840},
	abstract = {Ischemia/reperfusion may lead to graft dysfunction in heart transplantation (HT). The purpose of this study was to evaluate the influence of ischemic and reperfusion time on acute cellular rejection (ACR) within the first-year post-HT and on long-term outcomes. Data were collected from 331 patients (mean age 49 +/- 12 y, 28\% females) who underwent HT 1988-2016. Endomyocardial biopsies obtained within the first year after HT were graded according to the 2004-ISHLT-WF. We classified the patients by ischemic time {\textless}/{\textgreater}/=4 hours and further by reperfusion time {\textless}/{\textgreater}/=90 minutes. Primary endpoint was ACR {\textgreater}/= 2R within one-year post-HT. A multiple logistic regression analysis was used to adjust for potential confounders. Secondary endpoint was long-term survival. There were 56 (17\%) patients who received donor hearts with ischemic time {\textgreater}4 hours, and of these, 31 (55\%) patients had reperfusion with CPB {\textgreater}/=90 minutes. Ischemia {\textgreater}4 hours had an increased risk of ACR {\textgreater}/= 2R during the first year (adjusted OR = 3.1, P = .016); however, an extended reperfusion {\textgreater}/=90 minutes reduced the risk (adjusted OR = 0.25, P = .024). The conditional probability of surviving 10 years post-transplant, given that the patients already survived first year, was inferior for recipients with ischemia {\textgreater}/= 4 hours and reperfusion {\textless}90 minutes, 59\%, compared with the other groups 83\%, P = .016. Prolonged reperfusion appears to reduce the risk for ACR {\textgreater}/= 2R and improve long-term survival.},
	number = {5},
	journal = {Clin Transplant},
	author = {Jernryd, V. and Metzsch, C. and Andersson, B. and Nilsson, J.},
	month = may,
	year = {2020},
	keywords = {Adult, Female, Humans, Male, Middle Aged, *Heart Transplantation, Time Factors, heart transplantation, Tissue Donors, ischemic time, *Ischemia, acute cellular rejection, Graft Rejection/etiology, Reperfusion},
	pages = {e13840},
	file = {ctr.13840:/Users/johan/Zotero/storage/4KDYW5BE/ctr.13840.pdf:application/pdf;Jernryd-2020-The influence of ischemia and rep:/Users/johan/Zotero/storage/NAZNIBKE/Jernryd-2020-The influence of ischemia and rep.pdf:application/pdf},
}

