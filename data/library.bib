@article{ansari_induction_2015,
	title = {Induction with anti-thymocyte globulin in heart transplantation is associated with better long-term survival compared with basiliximab},
	volume = {34},
	issn = {1557-3117 (Electronic) 1053-2498 (Linking)},
	doi = {10.1016/j.healun.2015.04.001},
	abstract = {BACKGROUND: The use of induction therapy may reduce the risk of acute rejection after heart transplantation. This study assessed the association between basiliximab (BAS) vs anti-thymocyte globulin (ATG) induction and long-term survival after heart transplantation. METHODS: We used data from the International Society for Heart and Lung Transplantation Registry to examine outcomes of all adult heart transplant recipients treated with ATG or BAS as induction therapy. RESULTS: We identified 9,324 transplantations performed between 2000 and 2011 whose recipients received ATG (n = 6,144) or BAS (n = 3,180). The ATG group had a higher panel reactive antibody class 1 (7.5\% vs 6.1\%; p {\textless} 0.018) and class 2 (6.6\% vs 3.7\%; p {\textless} 0.001), respectively, whereas the BAS group was less likely to have non-ischemic cardiomyopathy but more likely to be in the intensive care unit pre-transplant. One-year survival was similar for both groups, 90\% vs 91\% (p = 0.858). However, use of BAS was associated with poorer long-term survival compared with ATG at 5 years (77\% vs 82\%, p = 0.005) and at 10 years (64\% vs 67\%, p = 0.007). In multivariable Cox model, use of BAS remained associated with increased mortality over a median follow-up of 3.0 years (range, 0-12 years), with a hazard ratio of 1.22 (95\% confidence interval, 1.09-1.37; p {\textless} 0.001). Sub-group analyses showed BAS was not independently associated with increased risk in those who received a previous transplant or in those who underwent re-transplantation due to graft failure. CONCLUSIONS: In the International Society for Heart and Lung Transplantation Registry experience, use of ATG rather than BAS as induction therapy appears to be associated with better long-term survival. A prospective study is necessary to confirm these findings.},
	number = {10},
	journal = {J Heart Lung Transplant},
	author = {Ansari, D. and Lund, L. H. and Stehlik, J. and Andersson, B. and Hoglund, P. and Edwards, L. and Nilsson, J.},
	month = oct,
	year = {2015},
	keywords = {Adult, Female, Humans, Male, Middle Aged, Registries, *Heart Transplantation, Young Adult, heart transplantation, graft failure, Graft Survival, mortality, Proportional Hazards Models, anti-thymocyte globulin, Antibodies, Monoclonal/*therapeutic use, Antilymphocyte Serum/*therapeutic use, Atg, Basiliximab, Cardiovascular Diseases/complications/mortality/*therapy, cardiovascular-related death, Graft Rejection/mortality/*prevention \& control, Immunosuppressive Agents/*therapeutic use, infection-related death, Recombinant Fusion Proteins/*therapeutic use},
	pages = {1283--91},
	file = {Ansari-2015-Induction with anti-thymocyte glob:/Users/johan/Zotero/storage/8GAF9PZ6/Ansari-2015-Induction with anti-thymocyte glob.pdf:application/pdf},
}

@article{ansari_comparison_2015,
	title = {Comparison of {Basiliximab} and {Anti}-{Thymocyte} {Globulin} as {Induction} {Therapy} in {Pediatric} {Heart} {Transplantation}: {A} {Survival} {Analysis}},
	volume = {5},
	issn = {2047-9980 (Electronic) 2047-9980 (Linking)},
	doi = {10.1161/JAHA.115.002790},
	abstract = {BACKGROUND: Basiliximab and anti-thymocyte globulin are widely used drugs for induction therapy after pediatric heart transplantation. The aim of this study was to determine whether any differences could be observed between basiliximab and anti-thymocyte globulin, with respect to long-term mortality, in a population of pediatric cardiac transplant recipients. METHODS AND RESULTS: An analysis of pediatric heart transplant patients (aged {\textless}18 years) from the United Network for Organ Sharing database was conducted that compared patients receiving basiliximab with those that received anti-thymocyte globulin for the risk of all-cause mortality. Secondary endpoints included death attributable to graft failure, cardiovascular causes, infection, or malignancy. Of the 2275 patients, 685 received basiliximab and 1590 anti-thymocyte globulin. One-year survival was similar for both groups; however, at 5 and 10 years, basiliximab was associated with poorer long-term survival (68\% versus 76\% at 5 years [P{\textless}0.001] and 49\% versus 65\% at 10 years [P{\textless}0.001], respectively). Basiliximab was associated with higher risk of death attributable to graft failure (P=0.013), but not death attributable to cardiovascular causes (P=0.444), infection (P=0.095), or malignancy (P=0.392). After multivariate analysis, use of basiliximab (versus use of anti-thymocyte globulin) remained significantly associated with all-cause mortality (hazard ratio, 1.27; 95\% confidence interval, 1.02-1.57; P=0.030). CONCLUSIONS: In pediatric heart transplant patients, use of basiliximab for induction therapy was associated with an increased risk of mortality, when compared with those receiving anti-thymocyte globulin.},
	number = {1},
	journal = {J Am Heart Assoc},
	author = {Ansari, D. and Hoglund, P. and Andersson, B. and Nilsson, J.},
	month = dec,
	year = {2015},
	keywords = {Adolescent, Female, Humans, Male, Risk Factors, Kaplan-Meier Estimate, Retrospective Studies, Registries, Time Factors, Cause of Death, Child, Child, Preschool, Treatment Outcome, Multivariate Analysis, Risk Assessment, survival, Databases, Factual, Proportional Hazards Models, Chi-Square Distribution, transplantation, Tissue and Organ Procurement, Age Factors, Basiliximab, Antibodies, Monoclonal/*adverse effects/therapeutic use, Antilymphocyte Serum/*adverse effects/therapeutic use, Heart Transplantation/adverse effects/*mortality, Immunosuppressive Agents/*adverse effects/therapeutic use, Induction Chemotherapy, pediatrics, Recombinant Fusion Proteins/*adverse effects/therapeutic use, United States},
	file = {Ansari-2015-Comparison of Basiliximab and Ant1:/Users/johan/Zotero/storage/YIN8T7J5/Ansari-2015-Comparison of Basiliximab and Ant1.pdf:application/pdf;Ansari-2015-Comparison of Basiliximab and Ant2:/Users/johan/Zotero/storage/UFTAIWC4/Ansari-2015-Comparison of Basiliximab and Ant2.pdf:application/pdf;Ansari-2015-Comparison of Basiliximab and Ant3:/Users/johan/Zotero/storage/7HRQKQQ9/Ansari-2015-Comparison of Basiliximab and Ant3.pdf:application/pdf;Ansari-2015-Comparison of Basiliximab and Ant4:/Users/johan/Zotero/storage/WV4JF7SJ/Ansari-2015-Comparison of Basiliximab and Ant4.pdf:application/pdf;Ansari-2015-Comparison of Basiliximab and Ant5:/Users/johan/Zotero/storage/JATF34NT/Ansari-2015-Comparison of Basiliximab and Ant5.pdf:application/pdf;Ansari-2015-Comparison of Basiliximab and Anti:/Users/johan/Zotero/storage/7RM8GG38/Ansari-2015-Comparison of Basiliximab and Anti.pdf:application/pdf},
}

@article{ansari_human_2014,
	title = {Human leukocyte antigen matching in heart transplantation: systematic review and meta-analysis},
	volume = {27},
	issn = {1432-2277 (Electronic) 0934-0874 (Linking)},
	doi = {10.1111/tri.12335},
	abstract = {Allocation of donors with regard to human leukocyte antigen (HLA) is controversial in heart transplantation. This paper is a systematic review and meta-analysis of the available evidence. PubMed, Embase, and the Cochrane Library were searched systematically for studies that addressed the effects of HLA matching on outcome after heart transplantation. Fifty-seven studies met the eligibility criteria. 34 studies had graft rejection as outcome, with 26 of the studies reporting a significant reduction in graft rejection with increasing degree of HLA matching. Thirteen of 18 articles that reported on graft failure found that it decreased significantly with increasing HLA match. Two multicenter studies and nine single-center studies provided sufficient data to provide summary estimates at 12 months. Pooled comparisons showed that graft survival increased with fewer HLA-DR mismatches [0-1 vs. 2 mismatches: risk ratio (RR) = 1.09 (95\% confidence interval (CI): 1.01-1.19; P = 0.04)]. Having fewer HLA-DR mismatches (0-1 vs. 2) reduced the incidence of acute rejection [(RR = 0.81 (0.66-0.99; P = 0.04)]. Despite the considerable heterogeneity between studies, the short observation time, and older data, HLA matching improves graft survival in heart transplantation. Prospective HLA-DR matching is clinically feasible and should be considered as a major selection criterion.},
	number = {8},
	journal = {Transpl Int},
	author = {Ansari, D. and Bucin, D. and Nilsson, J.},
	month = aug,
