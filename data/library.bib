@article{p00004,
	title = {Clinical outcome after poststernotomy mediastinitis: vacuum-assisted closure versus conventional treatment},
	volume = {79},
	issn = {1552-6259 (Electronic) 0003-4975 (Linking)},
	doi = {10.1016/j.athoracsur.2004.12.048},
	abstract = {BACKGROUND: The conventional treatment for poststernotomy mediastinitis usually involves surgical revision, closed irrigation, or reconstruction with omentum or pectoral muscle flaps. Recently, vacuum-assisted closure has been successfully used in poststernotomy mediastinitis. The aim of the present study was to compare the clinical outcome and survival in 101 patients undergoing vacuum-assisted closure therapy or conventional treatment for poststernotomy mediastinitis. METHODS: One hundred one consecutive patients underwent treatment for poststernotomy mediastinitis: vacuum-assisted closure therapy (January 1999 through December 2003, n = 61) or conventional treatment (July 1994 through December 1998, n = 40). Follow-up was made in April 2004 and was 100\% complete. Actuarial statistics were used to calculate the survival rates. RESULTS: The 90-days mortality was 0\% in the vacuum-assisted closure group and 15\% in the conventional treatment group (p {\textless} 0.01). The failure rate to first-line treatment with vacuum-assisted closure and conventional treatment were 0\% and 37.5\%, respectively (p {\textless} 0.001). There was no statistically significant difference in the recurrence of sternal fistulas after vacuum-assisted closure therapy or conventional treatment: 6.6\% versus 5.0\%, respectively. Overall survival in the vacuum-assisted closure group was significantly better (p {\textless} 0.05) than in the conventional treatment group: 97\% versus 84\% (6 months), 93\% versus 82\% (1 year), and 83\% versus 59\% (5 years). CONCLUSIONS: Our findings support that vacuum-assisted closure therapy is a safe and reliable option in poststernotomy mediastinitis with excellent survival and a very low failure rate compared with conventional treatment.},
	language = {eng},
	number = {6},
	journal = {Ann Thorac Surg},
	author = {Sjogren, J. and Gustafsson, R. and Nilsson, J. and Malmsjo, M. and Ingemansson, R.},
	month = jun,
	year = {2005},
	keywords = {Aged, Female, Humans, Male, Middle Aged, Retrospective Studies, Survival Analysis, Treatment Outcome, Sternum/*surgery, Vacuum, Cardiac Surgical Procedures, Mediastinal Diseases/*etiology/*surgery, Postoperative Complications/*etiology/*surgery, Surgical Procedures, Operative/*methods/mortality},
	pages = {2049--55},
	file = {Ann Thorac Surg 2005 Sjögren:/Users/johan/Zotero/storage/IUMB9X7B/Ann Thorac Surg 2005 Sjögren.pdf:application/pdf;Sjogren-2005-Clinical outcome after poststerno:/Users/johan/Zotero/storage/QIHCXAZ8/Sjogren-2005-Clinical outcome after poststerno.pdf:application/pdf},
}

@article{sjogren_negative-pressure_2011,
	title = {Negative-pressure wound therapy following cardiac surgery: bleeding complications and 30-day mortality in 176 patients with deep sternal wound infection},
	volume = {12},
	issn = {1569-9285 (Electronic) 1569-9285 (Linking)},
	doi = {10.1510/icvts.2010.252668},
	abstract = {Negative-pressure wound therapy (NPWT) has been used for the treatment of deep sternal wound infection (DSWI) with promising results. However, questions have been raised regarding the potential risk of right ventricle (RV) rupture during treatment. In the present study, we evaluate our clinical experience of NPWT focusing on RV rupture and major bleeding complications and its potentially negative impact on 30-day mortality during an 11-year period. Serious bleeding complications during NPWT were reviewed for 176 patients treated for DSWI between January 1999 and April 2010. The 30-day mortality following DSWI was 1.1\% (2/176). Four patients (2.3\%) suffered bleeding from the RV rupture during NPWT of the sternal wound (two spontaneous and two debridement related). Furthermore, two patients had debridement-related bleedings from the venous bypass grafts during wound dressing change. The very low 30-day mortality (1.1\%) following DSWI supports the use of NPWT. Overall, even if major bleeding complications may occur, the risk of RV rupture seems to be outweighed by the benefit of superior infection control. However, surgical experience is recommended when debriding sternal wounds and we recommend the use of a wound dressing, such as paraffin gauze, in order to protect the RV from direct contact with the polyurethane foam.},
	language = {eng},
	number = {2},
	journal = {Interactive cardiovascular and thoracic surgery},
	author = {Sjogren, J. and Gustafsson, R. and Nilsson, J. and Lindstedt, S. and Nozohoor, S. and Ingemansson, R.},
	month = feb,
	year = {2011},
	keywords = {Aged, Female, Humans, Male, Middle Aged, Retrospective Studies, Sweden, Follow-Up Studies, Aged, 80 and over, Cause of Death, Cohort Studies, Survival Rate, Risk Assessment, Cardiovascular Surgical Procedures/*adverse effects/methods/mortality, Hemorrhage/etiology/*mortality, Hospital Mortality/*trends, Negative-Pressure Wound Therapy/adverse effects/*methods, Reoperation/methods, Sternotomy/adverse effects/methods, Surgical Wound Infection/diagnosis/mortality/*surgery, Ventricular Septal Rupture/etiology/mortality},
	pages = {117--20},
