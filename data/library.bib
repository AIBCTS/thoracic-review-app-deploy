@article{axelsson_does_2021,
	title = {Does microbiological contamination of homografts prior to decontamination affect the outcome after right ventricular outflow tract reconstruction?},
	volume = {33},
	issn = {1569-9285 (Electronic) 1569-9293 (Print) 1569-9285 (Linking)},
	doi = {10.1093/icvts/ivab126},
	abstract = {OBJECTIVES: Homografts are often in short supply. Today, European guidelines recommend that all tissues contaminated by any of 18 different bacteria and fungi be discarded before antibiotic decontamination has been conducted. The tissue bank in Lund uses more liberal protocols: It accepts all microbes prior to decontamination except multiresistant microbes and Pseudomonas species. The aim of this study was to analyse the effect of contamination on the long-term outcome and occurrence of endocarditis in recipients. METHODS: Data were collected on homografts and on recipients of homografts in the right ventricular (RV) outflow tract who were operated on between 1995 and 2018 in Lund. The long-term outcome of recipients was analysed in relation to different types of contamination using Cox proportional hazard regression. The proportion of patients with endocarditis was analysed with the chi2 test. RESULTS: The study included 509 implanted homografts. Follow-up was a maximum of 24 years and 99\% complete. A total of 156 (31\%) homografts were contaminated prior to antibiotic decontamination. Homografts contaminated with low-risk microbes had the lowest reintervention rate, but there was no significant difference compared to no contamination [hazard ratio (HR) 1.1, 95\% confidence interval (CI) 0.73-1.7] or contamination with high-risk microbes (HR 1.6, 95\% CI 0.87-2.8) in the multivariable analysis. There was no significant difference in the proportion of cases of endocarditis during the follow-up period between recipients of homografts contaminated prior to decontamination and recipients of homografts with no contamination (P = 0.83). CONCLUSIONS: Contamination of homograft tissue prior to decontamination did not show any significant effect on the long-term outcome or the occurrence of endocarditis after implantation in the RV outflow tract. Most contaminated homografts can be used safely after approved decontamination.},
	number = {4},
	journal = {Interact Cardiovasc Thorac Surg},
	author = {Axelsson, I. and Malm, T. and Nilsson, J.},
	month = oct,
	year = {2021},
	keywords = {Humans, Homograft, Transplantation, Homologous, Treatment Outcome, *Decontamination, *Ventricular Outflow Obstruction, Allografts, Contamination, Heart Ventricles, Long-term outcome, Right ventricular outflow tract, Tissue bank},
	pages = {605--613},
	file = {Axelsson-2021-Does microbiological contaminati:/Users/johan/Zotero/storage/A8B9SIP3/Axelsson-2021-Does microbiological contaminati.pdf:application/pdf},
}

@article{axelsson_impact_2021,
	title = {Impact of valve fenestrations and structural changes in homografts on the long-term outcome in the recipient},
	volume = {22},
	issn = {1573-6814 (Electronic) 1389-9333 (Print) 1389-9333 (Linking)},
	doi = {10.1007/s10561-020-09886-5},
	abstract = {Homografts have long been used for right ventricular outflow tract (RVOT) reconstruction. Tissue banks struggle to meet the clinical demand of tissue, with insufficient donor availability and strict recommendations on tissue quality with high proportions of discards. This study analyzes the long-term outcome of patients receiving a homograft with small fenestrations of the cusps or other structural changes, to evaluate if minor impairment of the homograft affects the durability. Homograft characteristics and patient outcome were described. Follow-up was maximum 24 years. Structural changes of the homografts were analyzed in relation to patient outcome, using univariable and multivariable Cox proportional hazard regression. Between 1995 and 2018, 468 patients received 535 homografts in the RVOT in Lund. Median recipient age was 13 years. There were 137 (26.9\%) reinterventions. Freedom from reintervention was 75.8\% (95\% CI 71.3-79.7\%) at 10 years and 57.4\% (95\% CI 50.0-64.0\%) at 20 years. Small fenestrations of the cusps, fibrosis of the cusps and minor atheromatosis of the vessel did not show any statistically significant impact on long-term outcome, hazard ratio = 0.46 (95\% CI 0.11-1.87, p = 0.276) and hazard ratio = 0.80 (95\% CI 0.25-2.56, p = 0.704). Minor structural changes of the homografts seem to be acceptable without affecting the long-term durability.},
	number = {3},
	journal = {Cell Tissue Bank},
	author = {Axelsson, I. and Malm, T. and Nilsson, J.},
	month = sep,
	year = {2021},
	keywords = {Adolescent, Humans, Retrospective Studies, Homograft, Transplantation, Homologous, Infant, Treatment Outcome, Reoperation, Proportional Hazards Models, Allografts, Long-term outcome, Right ventricular outflow tract, Tissue bank, *Plastic Surgery Procedures, *Pulmonary Valve, *Ventricular Outflow Obstruction/surgery, Valve fenestrations},
	pages = {399--408},
	file = {Axelsson-2021-Impact of valve fenestrations an:/Users/johan/Zotero/storage/LFIIBBTG/Axelsson-2021-Impact of valve fenestrations an.pdf:application/pdf;Fenestration, proof reading copy:/Users/johan/Zotero/storage/VJXUJVMX/Fenestration, proof reading copy.pdf:application/pdf},
