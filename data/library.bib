@article{dafni_landmark_2011,
	title = {Landmark {Analysis} at the 25-{Year} {Landmark} {Point}},
	volume = {4},
	issn = {1941-7713, 1941-7705},
	url = {https://www.ahajournals.org/doi/10.1161/CIRCOUTCOMES.110.957951},
	doi = {10.1161/CIRCOUTCOMES.110.957951},
	abstract = {This statistical primer presents the landmark analysis method, exploring its appropriate use and interpretation while recognizing its limitations. This observational method is used for comparing time-to-event outcome between groups determined during study follow-up. The goal of the landmark method is to estimate in an unbiased way the time-to-event probabilities in each group conditional on the group membership of patients at a specific time point, the landmark time. The need that led to its development, the impact of the method, and its pros and cons, along with available alternative approaches, are presented. Simulations explore its performance, using realistic parameters from a recent cardiovascular study. As long as the limitations of the method are recognized and the interpretation of its results clearly reflect their “conditional” nature, landmark analysis, 25 years from its introduction, can still be of value.},
	language = {en},
	number = {3},
	urldate = {2026-01-13},
	journal = {Circulation: Cardiovascular Quality and Outcomes},
	author = {Dafni, Urania},
	month = may,
	year = {2011},
	pages = {363--371},
}

@article{kampaktsis_characteristics_2022,
	title = {Characteristics, {Predictors}, and {Outcomes} of {Early} {mTOR} {Inhibitor} {Use} {After} {Heart} {Transplantation}: {Insights} {From} the {UNOS} {Database}},
	volume = {11},
	issn = {2047-9980},
	shorttitle = {Characteristics, {Predictors}, and {Outcomes} of {Early} {mTOR} {Inhibitor} {Use} {After} {Heart} {Transplantation}},
	url = {https://www.ahajournals.org/doi/10.1161/JAHA.122.025507},
	doi = {10.1161/JAHA.122.025507},
	abstract = {Background
              The clinical characteristics of mTOR (mammalian target of rapamycin) inhibitors use in heart transplant recipients and their outcomes have not been well described.
            
            
              Methods and Results
              
                We compared patients who received mTOR inhibitors within the first 2 years after heart transplantation to patients who did not by inquiring the United Network for Organ Sharing (UNOS) database between 2010 and 2018. The primary end point was all‐cause mortality with retransplantation as a competing event. Rejection, malignancy, hospitalization for infection, and renal transplantation were secondary end points. There were 1619 (9\%) and 15 686 (81\%) mTOR inhibitors+ and mTOR inhibitors− patients, respectively. Body mass index, induction, cardiac allograft vasculopathy, calculated panel reactive antibody, and fewer days in 1A status were independently associated with mTOR inhibitors+ status. Over a follow‐up of 10.4 years, there was no difference in all‐cause mortality after adjusting for donor and recipient characteristics (adjusted subdistribution hazard ratio, 1.03 [0.90–1.19];
                P
                =0.66). mTOR inhibitors+ were independently associated with increased risk for rejection (odds ratio [OR], 1.43 [1.11–1.83];
                P
                =0.005) and basal skin cancer (OR, 1.35 [1.19–1.51];
                P
                =0.012) but not for infection or renal transplantation.
              
            
            
              Conclusions
              mTOR inhibitors are used in {\textless}10\% patients in the first 2 years after heart transplantation and are noninferior to contemporary immunosuppression regimens in terms of all‐cause mortality, infection, malignancy, or renal transplantation. They are associated with risk for rejection.},
	language = {en},
	number = {17},
	urldate = {2026-01-13},
	journal = {Journal of the American Heart Association},
	author = {Kampaktsis, Polydoros N. and Doulamis, Ilias P. and Asleh, Rabea and Makri, Elpiniki and Kalamaras, Ilias and Papastergiopoulos, Christoforos and Emfietzoglou, Maria and Drosou, Anastasis and Van Den Eynde, Jef and Alnsasra, Hilmi and Duque, Ernesto Ruiz and Briasoulis, Alexandros},
	month = sep,
	year = {2022},
	pages = {e025507},
	file = {Full Text:/Users/johan/Zotero/storage/HXZ8LUTI/Kampaktsis et al. - 2022 - Characteristics, Predictors, and Outcomes of Early mTOR Inhibitor Use After Heart Transplantation I.pdf:application/pdf},
}

