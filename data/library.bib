@article{bergenfeldt_outcomes_2015,
	title = {Outcomes after {ABO}-incompatible heart transplantation in adults: {A} registry study},
	volume = {34},
	issn = {1557-3117 (Electronic) 1053-2498 (Linking)},
	doi = {10.1016/j.healun.2015.01.008},
	abstract = {BACKGROUND: In the past, ABO incompatibility was considered an absolute contraindication to heart transplantation (HT) in adults. Advances in ABO-incompatible HT in pediatric patients and ABO-incompatible abdominal transplantation in adult patients have led to clinical exploration of intentional ABO-incompatible HT in adults. However, it is not well known how outcomes in ABO-incompatible adult heart transplant recipients compare with outcomes in ABO-compatible recipients. METHODS: We analyzed International Society for Heart and Lung Transplantation transplant registry data from heart donors and recipients {\textgreater}/=18 years old at the time of transplant for HT performed between 1988 and 2011. We compared baseline characteristics and post-transplant outcomes in ABO-incompatible and ABO-compatible HT. Death or retransplantation was the composite primary end-point. RESULTS: Among 76,663 adult patients undergoing HT between 1988 and June 30, 2011, 94 ABO-incompatible heart transplants were performed. The incidence of death or retransplantation in the ABO-incompatible group was higher than in the ABO-compatible group: 21\% vs 9\% at 30 days (hazard ratio = 2.38, p {\textless} 0.001) and 36\% vs 19\% at 1 year after transplant. However, ABO-incompatible grafts surviving past the first year after transplant had a similar incidence of failure compared with the ABO-compatible group. After 2005, the rate ABO-incompatible HT in adults increased, likely as a result of planned, intentional (rather than accidental) ABO-incompatible HT. In this group of patients, short-term and long-term incidence of death or retransplantation was similar to ABO-compatible recipients (p = 0.822): 7\% at 30 days and 19\% at 1 year after transplantation. CONCLUSIONS: We found no difference in incidence of death or retransplantation between ABO-compatible and ABO-incompatible HT in patients who underwent transplantation after 2005.},
	number = {7},
	journal = {J Heart Lung Transplant},
	author = {Bergenfeldt, H. and Andersson, B. and Bucin, D. and Stehlik, J. and Edwards, L. and Radegran, G. and Nilsson, J.},
	month = jul,
	year = {2015},
	keywords = {Adolescent, Adult, Female, Humans, Male, Middle Aged, Risk Factors, Retrospective Studies, Incidence, Sweden/epidemiology, Time Factors, Young Adult, Follow-Up Studies, Survival Rate/trends, heart transplantation, Graft Survival, *Risk Assessment, ABO Blood-Group System/*immunology, Heart Transplantation/*adverse effects, Abo, Blood Group Incompatibility/epidemiology/*immunology, blood group incompatible heart transplant, Graft Rejection/epidemiology/*immunology},
	pages = {892--8},
	file = {Bergenfeldt-2015-Outcomes after ABO-incompatib:/Users/johan/Zotero/storage/NHH7AYLN/Bergenfeldt-2015-Outcomes after ABO-incompatib.pdf:application/pdf},
}

@article{bereza-carlson_preoperative_2022,
	title = {Preoperative {Risk} {Score} for {Early} {Mortality} {After} {Up}-{Front} {Pancreatic} {Cancer} {Surgery}: {A} {Nationwide} {Cohort} {Study}},
	volume = {46},
	issn = {1432-2323 (Electronic) 0364-2313 (Print) 0364-2313 (Linking)},
	doi = {10.1007/s00268-022-06678-8},
	abstract = {BACKGROUND: Pancreatic ductal adenocarcinoma is a highly fatal malignancy. The aim was to identify preoperative factors for early mortality in up-front resectable patients following pancreatoduodenectomy (PD) and develop an early mortality risk score. METHODS: Patients registered in the Swedish National Registry for Pancreatic and Periampullary Cancer were included. Relevant preoperative factors (n = 21) were investigated. Early mortality was defined as death within 12 months after surgery. Based on the identified risk factor odds ratios (ORs), the Score Predicting Early Mortality (SPEM) was developed. RESULTS: In total, 2183 PDs were performed, and 926 patients met the study criteria. The mean age was 68 (SD +/- 8.8) years, and 48\% were female. A total of 233 (24\%) patients died within 12 months. In the multivariable analyses, age {\textgreater} 75 years (OR 1.7; 95\% CI 1.1-2.4; p = 0.008), CRP {\textgreater}/= 15 mg/L (OR 2.0; 95\% CI 1.3-3.1; p = 0.001), CA 19-9 {\textgreater} 500 U/mL (OR 1.8; 95\% CI 1.0-3.2; p = 0.040), diabetes mellitus (OR 1.40; 95\% CI 1.00-2.1; p = 0.042), and active smoking (OR 1.47; 95\%CI 1.00-2.00; p = 0.050) were found to be independent risk factors for early mortality. CONCLUSION: Five independent preoperative risk factors for early mortality following PD were identified and together formed SPEM. The score might be a useful tool in establishing individualized treatment plans.},
	number = {11},
	journal = {World J Surg},
	author = {Bereza-Carlson, P. and Nilsson, J. and Andersson, B.},
	month = nov,
	year = {2022},
	keywords = {Aged, Female, Humans, Male, Risk Factors, Retrospective Studies, Cohort Studies, *Pancreatic Neoplasms/pathology, *Carcinoma, Pancreatic Ductal/surgery},
	pages = {2769--2777},
	file = {Bereza-Carlson-2022-Preoperative Risk Score fo:/Users/johan/Zotero/storage/DAIACQJJ/Bereza-Carlson-2022-Preoperative Risk Score fo.pdf:application/pdf},
}

