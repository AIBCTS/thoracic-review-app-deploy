}

@inproceedings{yao_clinicians_2024,
	title = {Do {Clinicians} {Know} {How} to {Prompt}? {The} {Need} for {Automatic} {Prompt} {Optimization} {Help} in {Clinical} {Note} {Generation}},
	isbn = {979-889176130-8 (ISBN)},
