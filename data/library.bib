@article{r01070,
	chapter = {S68},
	title = {184 {Artificial} {Neural} {Networks} - {Relative} {Importance} of {Different} {Recipient}-{Donor} {Characteristic} {Combinations} on {Survival} after {Heart} {Transplantation}},
	volume = {30},
	issn = {10532498},
	doi = {10.1016/j.healun.2011.01.191},
	abstract = {Purpose: Criteria for matching potential recipients with the appropriate donor are based primarily on blood-group, age, body size and and ischemic time. No multi-institutional study has comprehensively eval- uate the relative importance of these matching criteria for long-term survival.
Methods and Materials: We used data from the multi-institutional pro- spectively collected ISHLT registry to review 59698 adult heart trans- planted. The survival, calculated as area under survival curve, were pre- dicted for the recipient-donor characteristic combinations using artificial neural networks and the relative importance using regression tree.
Results: In total 29160 simulation for each patient in the cohort were performed. Recipient and donor age had the greatest impact on survival followed by ischemic duration, gender and blood-group match, Figure 1.
Body size was not recognized to be important in the first six level of the regression tree. A weight match for donor weight above 70 kg did not improve survival, Figure 2.
Conclusions: The ISHLT data set has provided a large sample of donor- recipient characteristic in orthotopic heart transplantation. Using advanced simulation techniques the relative importance of the different recipient- donor combinations could be achieved. The donor age, ischemic duration and gender match prove to be more important than identical blood-group match.},
	number = {4},
	journal = {The Journal of Heart and Lung Transplantation},
	publisher = {Elsevier Inc.},
	author = {Nilsson, J. and Ohlsson, M. and Höglund, P. and Ekmehag, B. and Koul, B. and Andersson, B.},
	year = {2011},
	pages = {S68},
	file = {The Journal of Heart and Lung Transplantation 2011 Nilsson:/Users/johan/Zotero/storage/FRMDTLJE/The Journal of Heart and Lung Transplantation 2011 Nilsson.pdf:application/pdf},
}

@article{r01077,
	chapter = {S29},
	title = {69: {Artificial} {Neural} {Networks} – {A} {Method} for {Optimal} {Donor}-{Recipient} {Matching}. {Large} {Scale} {Simulation} of {Survival} after {Heart} {Transplantation}},
	volume = {29},
	issn = {10532498},
	doi = {10.1016/j.healun.2009.11.077},
	abstract = {Purpose: Criteria for matching potential recipients with the appropriate donor are based primarily on blood group compatibility and patient size. However, several other risk factors such as gender, HLA, medical condi- tion prior to transplantation and duration of ischemia may influence out- comes. This study aim to develop an individual prediction model for long-term survival and simulate outcomes using different recipient-donor characteristic combinations.
Methods and Materials: Patient and donor data were collected from the ISHLT registry (59 698 adult patients). Important risk variables and HLA phenotypes were ranked and minimized in number by calibrated artificial neural networks (ANN). The long term survival and optimum match between recepient-donor pairs were calculated using ANN and Monte Carlo simulation technique with High Performance Computer Cluster. Results: 14 donor and 21 recipient risk variables were found relevant for survival prediction. The predicted five-year survival was 77\% in best donor-recipient match and best simulated match, 56\% in worse donor- recipient match, and 42\% in worse simulated match, Figure 1A. Duration of ischemia influence the survival dramatically already at a donor age above 30 years, Figure 1B.[figure1]
Conclusions: ANN can be used to predict individual survival. A “virtual cross-match” model using ANN allow transplant physicians to stratify risk-benefit analysis inherent to any donor offer. Simulation of future outcome for each patient on the waiting list would make it possible to avoid worse case match, and to choose best possible match in the clinical setting.},
	number = {2},
	journal = {The Journal of Heart and Lung Transplantation},
	publisher = {Elsevier Inc.},
	author = {Nilsson, J. and Ohlsson, M. and Hoglund, P. and Ekmehag, B. and Koul, B.},
	year = {2010},
	pages = {S29--S29},
	file = {The Journal of Heart and Lung Transplantation 2010 Nilsson:/Users/johan/Zotero/storage/BRVU8GL8/The Journal of Heart and Lung Transplantation 2010 Nilsson.pdf:application/pdf},
}

